DATABASE_URL="file:./prisma/dev.db"

# Default LLM for system features (Prompt generation, etc.)
# This is separate from each Agent's own model configuration.
# Supported providers: openai, anthropic, google, openrouter, deepseek
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# LLM Provider API Keys (configure the ones you need)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
