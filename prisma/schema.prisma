// Bossman - AI Company Management Platform
// Prisma Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Company ─────────────────────────────────────────────────────────────────

model Company {
  id          String     @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
  projects    Project[]
  skills      Skill[]
}

// ─── Skill (market or custom, attachable to employees and roles) ──────────────

model Skill {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String   // markdown or text: skill definition / instructions
  source      String   @default("custom") // "market" | "custom"
  companyId   String?  // null = market/global; set = company-uploaded
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   EmployeeSkill[]
  roles       AgentRoleSkill[]
}

// ─── Agent Role (template) ───────────────────────────────────────────────────

model AgentRole {
  id           String           @id @default(cuid())
  name         String           @unique // e.g. "ceo", "frontend-dev"
  title        String // e.g. "CEO", "Frontend Developer"
  systemPrompt String
  modelConfig  String // JSON string: { provider, model, temperature, ... }
  capabilities String? // JSON string: available tools/capabilities
  isBuiltin    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  employees    Employee[]
  skills       AgentRoleSkill[]
}

// ─── Employee (Agent instance in a company) ──────────────────────────────────

model Employee {
  id              String          @id @default(cuid())
  companyId       String
  roleId          String
  name            String
  status          String          @default("idle") // idle, busy, offline
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role            AgentRole       @relation(fields: [roleId], references: [id])
  assignments     TaskAssignment[]
  messages        Message[]       @relation("SenderMessages")
  projectFiles    ProjectFile[]
  tokenUsages     TokenUsage[]
  directMessages  DirectMessage[]
  skills          EmployeeSkill[]
  inboxItems      EmployeeInbox[]
  sentConvMsgs    ConversationMessage[] @relation("ConvMsgFrom")
  recvConvMsgs    ConversationMessage[] @relation("ConvMsgTo")
  conversationThreads ConversationThread[] @relation("ThreadCreatedBy")
}

model EmployeeSkill {
  employeeId String
  skillId    String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  @@id([employeeId, skillId])
}

model AgentRoleSkill {
  roleId   String
  skillId  String
  role     AgentRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  skill    Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  @@id([roleId, skillId])
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  companyId   String
  name        String
  description String        @default("")
  document    String?       // Markdown: compiled project document
  status      String        @default("active") // active, review, done, blocked, canceled
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks       Task[]
  messages    Message[]
  files       ProjectFile[]
  tokenUsages TokenUsage[]
  projectTransitions ProjectTransition[]
  taskTransitions    TaskTransition[]
  conversationThreads ConversationThread[]
  conversationMessages ConversationMessage[]
  inboxItems          EmployeeInbox[]
  timelineEvents      EngineTimelineEvent[]
}

// ─── Project File (employee deliverable) ────────────────────────────────────

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  employeeId String
  taskId     String?  // optional: which task this came from
  title      String   // filename or "path/filename", e.g. "PRD.md", "src/Button.tsx"
  path       String?  // optional dir path in workspace, e.g. "docs", "src"
  content    String   // markdown or source code
  brief      String?  // short summary for chat preview
  fileType   String   @default("document") // "document" | "code"
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

// ─── Task ────────────────────────────────────────────────────────────────────

model Task {
  id          String         @id @default(cuid())
  projectId   String
  parentId    String? // for sub-tasks
  title       String
  description String
  status      String         @default("todo") // todo, in_progress, review, done, blocked, canceled
  priority    Int            @default(0) // higher = more important
  output      String?        // agent's deliverable / result
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      Task?          @relation("SubTasks", fields: [parentId], references: [id])
  subTasks    Task[]         @relation("SubTasks")
  assignments TaskAssignment[]
  messages    Message[]
  files       ProjectFile[]
  taskTransitions TaskTransition[]
  conversationThreads ConversationThread[]
  conversationMessages ConversationMessage[]
  inboxItems EmployeeInbox[]
  timelineEvents EngineTimelineEvent[]
}

// ─── Task Assignment ─────────────────────────────────────────────────────────

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String
  employeeId String
  assignedAt DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([taskId, employeeId])
}

// ─── Message ─────────────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(cuid())
  projectId  String
  taskId     String?
  senderId   String? // null for system / founder messages
  senderType String // "founder", "agent", "system"
  content    String
  metadata   String? // JSON string: additional data
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  sender     Employee? @relation("SenderMessages", fields: [senderId], references: [id], onDelete: SetNull)
}

// ─── Direct Message (1:1 chat with employees) ──────────────────────────────

model DirectMessage {
  id         String   @id @default(cuid())
  employeeId String
  role       String // "user" or "assistant"
  content    String
  metadata   String? // JSON string: { images: ["data:image/..."] }
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── Token Usage ─────────────────────────────────────────────────────────────

model TokenUsage {
  id           String   @id @default(cuid())
  employeeId   String
  projectId    String?
  model        String
  provider     String
  inputTokens  Int
  outputTokens Int
  cost         Float? // estimated cost in USD
  createdAt    DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model ProjectTransition {
  id         String   @id @default(cuid())
  projectId  String
  fromStatus String
  toStatus   String
  reason     String
  actor      String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TaskTransition {
  id         String   @id @default(cuid())
  taskId     String
  projectId  String
  fromStatus String
  toStatus   String
  reason     String
  actor      String
  createdAt  DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ConversationThread {
  id        String   @id @default(cuid())
  projectId String
  taskId    String?
  subject   String
  createdBy String
  status    String   @default("open")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  creator   Employee @relation("ThreadCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)
  messages  ConversationMessage[]
  inboxItems EmployeeInbox[]
}

model ConversationMessage {
  id             String   @id @default(cuid())
  threadId       String
  projectId      String
  taskId         String?
  fromEmployeeId String?
  toEmployeeId   String?
  messageType    String
  content        String
  payload        String?
  createdAt      DateTime @default(now())
  thread         ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task           Task?              @relation(fields: [taskId], references: [id], onDelete: SetNull)
  fromEmployee   Employee?          @relation("ConvMsgFrom", fields: [fromEmployeeId], references: [id], onDelete: SetNull)
  toEmployee     Employee?          @relation("ConvMsgTo", fields: [toEmployeeId], references: [id], onDelete: SetNull)
  inboxItems     EmployeeInbox[]
}

model EmployeeInbox {
  id         String   @id @default(cuid())
  employeeId String
  projectId  String
  taskId     String?
  threadId   String?
  messageId  String?
  status     String   @default("pending") // pending, processing, done, expired
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task       Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  thread     ConversationThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  message    ConversationMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
}

model EngineTimelineEvent {
  id        String   @id @default(cuid())
  projectId String
  taskId    String?
  eventType String
  actor     String
  summary   String
  payload   String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}
